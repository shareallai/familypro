---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCardList from '../../../components/PostCardList.astro';
import {
  DEFAULT_LANG,
  buildBlogIndexDescription,
  buildBlogIndexTitle,
  collectSiteLangs,
  getLangLabel,
  getLocaleCode,
  getSiteName,
  getUi,
  type Lang,
} from '../../../lib/i18n';

interface Props {
  siteLangs: Lang[];
}

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const siteLangs = collectSiteLangs(posts.map((post) => post.data.locale));
  return siteLangs.map((lang) => ({ params: { lang }, props: { siteLangs } }));
}

const { siteLangs } = Astro.props as Props;
const lang = (Astro.params.lang ?? DEFAULT_LANG).toLowerCase();
const activeLangs = collectSiteLangs(siteLangs);
if (!activeLangs.includes(lang)) {
  throw new Error(`Unsupported language: ${lang}`);
}
const ui = getUi(lang);
const siteName = getSiteName(lang);
const localeCode = getLocaleCode(lang);

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.locale === lang)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const postCards = posts.map((post) => {
  const publishedAt = post.data.pubDate;
  const modifiedAt = post.data.updatedDate ?? publishedAt;
  return {
    post,
    publishedDateText: publishedAt.toISOString().slice(0, 10),
    modifiedDateText: modifiedAt.toISOString().slice(0, 10),
    showUpdatedDate: modifiedAt.getTime() > publishedAt.getTime(),
  };
});

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
const siteBase = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(`${baseUrl}${lang}/blog/`, siteBase).toString();

const alternates = activeLangs.map((code) => ({
  hrefLang: getLocaleCode(code),
  href: new URL(`${baseUrl}${code}/blog/`, siteBase).toString(),
}));
alternates.push({ hrefLang: 'x-default', href: new URL(`${baseUrl}${DEFAULT_LANG}/blog/`, siteBase).toString() });

const languageLinks = activeLangs.map((code) => ({
  label: getLangLabel(code),
  href: `${baseUrl}${code}/blog/`,
  active: code === lang,
}));

const title = buildBlogIndexTitle(lang, siteName, ui.allPosts);
const description = buildBlogIndexDescription(lang, ui.allPosts);
const getCoverImageSrc = (src?: string) => (src ? (/^https?:\/\//.test(src) ? src : `${baseUrl}${src.replace(/^\/+/, '')}`) : undefined);
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: canonical,
  inLanguage: localeCode,
  description,
};

const getPostSlug = (id: string) => id.split('/').pop() ?? id;
const listItems = postCards.map(({ post, publishedDateText, modifiedDateText, showUpdatedDate }) => ({
  href: `${baseUrl}${lang}/blog/${getPostSlug(post.id)}/`,
  title: post.data.title,
  summary: post.data.summary,
  category: post.data.category,
  coverImageSrc: getCoverImageSrc(post.data.coverImage),
  meta: `${ui.publishedLabel} ${publishedDateText}${showUpdatedDate ? ` · ${ui.updatedLabel} ${modifiedDateText}` : ''} · ${post.data.service} · ${post.data.tags.join(' / ')}`,
}));
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lang={lang}
  localeCode={localeCode}
  siteName={siteName}
  homeLabel={ui.home}
  blogLabel={ui.blog}
  footerText={ui.footer}
  navHomeHref={`${baseUrl}${lang}/`}
  navBlogHref={`${baseUrl}${lang}/blog/`}
  languageLabel={ui.languageSwitch}
  languageLinks={languageLinks}
  alternates={alternates}
  jsonLd={websiteJsonLd}
>
  <section class="index-hero">
    <p class="index-kicker">{ui.blog}</p>
    <h1>{ui.allPosts}</h1>
    <p class="index-desc">{description}</p>
  </section>

  <section class="index-list">
    {listItems.length === 0 ? (
      <p>{ui.noPosts}</p>
    ) : (
      <PostCardList items={listItems} />
    )}
  </section>
</BaseLayout>

<style>
  .index-hero {
    background:
      linear-gradient(180deg, rgba(236, 254, 255, 0.7) 0%, rgba(255, 255, 255, 0.92) 52%, #ffffff 100%),
      repeating-linear-gradient(90deg, transparent 0, transparent 22px, rgba(15, 23, 42, 0.016) 22px, rgba(15, 23, 42, 0.016) 23px);
    border: 1px solid var(--line);
    border-radius: 1rem;
    padding: 1.24rem 1.2rem 1.1rem;
    box-shadow: var(--shadow-card);
    margin-bottom: 1rem;
  }

  .index-kicker {
    margin: 0;
    color: #0f766e;
    font-weight: 700;
    font-size: 0.79rem;
    letter-spacing: 0.075em;
    text-transform: uppercase;
  }

  .index-hero h1 {
    margin: 0.44rem 0 0.48rem;
  }

  .index-desc {
    margin: 0;
    max-width: 64ch;
    color: var(--text-soft);
  }

  .index-list {
    margin-top: 0.95rem;
  }
</style>
