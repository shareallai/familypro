---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  DEFAULT_LANG,
  buildBlogIndexDescription,
  buildBlogIndexTitle,
  collectSiteLangs,
  getLangLabel,
  getLocaleCode,
  getSiteName,
  getUi,
  type Lang,
} from '../../../lib/i18n';

interface Props {
  siteLangs: Lang[];
}

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const siteLangs = collectSiteLangs(posts.map((post) => post.data.locale));
  return siteLangs.map((lang) => ({ params: { lang }, props: { siteLangs } }));
}

const { siteLangs } = Astro.props as Props;
const lang = (Astro.params.lang ?? DEFAULT_LANG).toLowerCase();
const activeLangs = collectSiteLangs(siteLangs);
if (!activeLangs.includes(lang)) {
  throw new Error(`Unsupported language: ${lang}`);
}
const ui = getUi(lang);
const siteName = getSiteName(lang);
const localeCode = getLocaleCode(lang);

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.locale === lang)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
const siteBase = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(`${baseUrl}${lang}/blog/`, siteBase).toString();

const alternates = activeLangs.map((code) => ({
  hrefLang: getLocaleCode(code),
  href: new URL(`${baseUrl}${code}/blog/`, siteBase).toString(),
}));
alternates.push({ hrefLang: 'x-default', href: new URL(`${baseUrl}${DEFAULT_LANG}/blog/`, siteBase).toString() });

const languageLinks = activeLangs.map((code) => ({
  label: getLangLabel(code),
  href: `${baseUrl}${code}/blog/`,
  active: code === lang,
}));

const title = buildBlogIndexTitle(lang, siteName, ui.allPosts);
const description = buildBlogIndexDescription(lang, ui.allPosts);
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: canonical,
  inLanguage: localeCode,
  description,
};

const getPostSlug = (id: string) => id.split('/').pop() ?? id;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lang={lang}
  localeCode={localeCode}
  siteName={siteName}
  homeLabel={ui.home}
  blogLabel={ui.blog}
  footerText={ui.footer}
  navHomeHref={`${baseUrl}${lang}/`}
  navBlogHref={`${baseUrl}${lang}/blog/`}
  languageLabel={ui.languageSwitch}
  languageLinks={languageLinks}
  alternates={alternates}
  jsonLd={websiteJsonLd}
>
  <h1>{ui.allPosts}</h1>

  {posts.length === 0 ? (
    <p>{ui.noPosts}</p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li class="card">
          <a href={`${baseUrl}${lang}/blog/${getPostSlug(post.id)}/`}>
            <h2>{post.data.title}</h2>
          </a>
          <p>{post.data.description}</p>
          <p class="meta">
            {post.data.pubDate.toISOString().slice(0, 10)} · {post.data.service} · {post.data.tags.join(' / ')}
          </p>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

<style>
  .post-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .card {
    background: #ffffff;
    border: 1px solid #dbe5ef;
    border-radius: 0.9rem;
    padding: 1rem;
  }

  .card h2 {
    margin: 0;
    font-size: 1.1rem;
  }

  .card p {
    margin: 0.4rem 0;
  }

  .meta {
    color: #64748b;
    font-size: 0.92rem;
  }
</style>
