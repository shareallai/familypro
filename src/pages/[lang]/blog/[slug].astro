---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  DEFAULT_LANG,
  collectSiteLangs,
  getLangLabel,
  getLocaleCode,
  getSiteName,
  getUi,
  type Lang,
} from '../../../lib/i18n';

type TranslationRef = { lang: Lang; slug: string };

export async function getStaticPaths() {
  const getPostSlug = (id: string) => id.split('/').pop() ?? id;
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const siteLangs = collectSiteLangs(posts.map((post) => post.data.locale));
  const byTranslation = new Map<string, CollectionEntry<'blog'>[]>();

  for (const post of posts) {
    const key = post.data.translationKey;
    byTranslation.set(key, [...(byTranslation.get(key) ?? []), post]);
  }

  return posts.map((post) => {
    const translations = (byTranslation.get(post.data.translationKey) ?? []).map((item) => ({
      lang: item.data.locale,
      slug: getPostSlug(item.id),
    }));

    return {
      params: { lang: post.data.locale, slug: getPostSlug(post.id) },
      props: { post, translations, siteLangs },
    };
  });
}

interface Props {
  post: CollectionEntry<'blog'>;
  translations: TranslationRef[];
  siteLangs: Lang[];
}

const { post, translations, siteLangs } = Astro.props as Props;
const currentLang = post.data.locale;
const ui = getUi(currentLang);
const localeCode = getLocaleCode(currentLang);
const siteName = getSiteName(currentLang);
const visibleHeadline = post.data.headline ?? post.data.title;
const activeLangs = collectSiteLangs(siteLangs);
const { Content, headings } = await render(post);
const tocH2Headings = headings.filter(
  (heading) => heading.depth === 2 && heading.text.trim().length > 0 && heading.slug.trim().length > 0,
);
const MIN_TOC_H2_COUNT = 3;
const shouldShowToc = tocH2Headings.length >= MIN_TOC_H2_COUNT;
const getPostSlug = (id: string) => id.split('/').pop() ?? id;
const publishedAt = post.data.pubDate;
const modifiedAt = post.data.updatedDate ?? publishedAt;
const publishedDateText = publishedAt.toISOString().slice(0, 10);
const modifiedDateText = modifiedAt.toISOString().slice(0, 10);
const showUpdatedDate = modifiedAt.getTime() > publishedAt.getTime();
const metaParts = [`${ui.publishedLabel} ${publishedDateText}`];
if (showUpdatedDate) {
  metaParts.push(`${ui.updatedLabel} ${modifiedDateText}`);
}
metaParts.push(post.data.service);
metaParts.push(`${ui.articleBy} ${post.data.author}`);

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
const siteBase = Astro.site ?? new URL(Astro.url.origin);
const currentSlug = getPostSlug(post.id);
const canonical = new URL(`${baseUrl}${currentLang}/blog/${currentSlug}/`, siteBase).toString();
const coverImageSrc = post.data.coverImage
  ? /^https?:\/\//.test(post.data.coverImage)
    ? post.data.coverImage
    : `${baseUrl}${post.data.coverImage.replace(/^\/+/, '')}`
  : undefined;

const alternates = translations.map((item) => ({
  hrefLang: getLocaleCode(item.lang),
  href: new URL(`${baseUrl}${item.lang}/blog/${item.slug}/`, siteBase).toString(),
}));

const defaultTranslation = translations.find((item) => item.lang === DEFAULT_LANG) ?? translations[0];
if (defaultTranslation) {
  alternates.push({
    hrefLang: 'x-default',
    href: new URL(`${baseUrl}${defaultTranslation.lang}/blog/${defaultTranslation.slug}/`, siteBase).toString(),
  });
}

const languageLinks = activeLangs.map((lang) => {
  const hit = translations.find((item) => item.lang === lang);
  return {
    label: getLangLabel(lang),
    href: hit ? `${baseUrl}${lang}/blog/${hit.slug}/` : `${baseUrl}${lang}/blog/`,
    active: lang === currentLang,
  };
});

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: visibleHeadline,
  description: post.data.description,
  datePublished: publishedAt.toISOString(),
  dateModified: modifiedAt.toISOString(),
  inLanguage: localeCode,
  author: {
    '@type': 'Person',
    name: post.data.author,
  },
  mainEntityOfPage: canonical,
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={canonical}
  lang={currentLang}
  localeCode={localeCode}
  siteName={siteName}
  homeLabel={ui.home}
  blogLabel={ui.blog}
  footerText={ui.footer}
  navHomeHref={`${baseUrl}${currentLang}/`}
  navBlogHref={`${baseUrl}${currentLang}/blog/`}
  languageLabel={ui.languageSwitch}
  languageLinks={languageLinks}
  alternates={alternates}
  image={coverImageSrc}
  type="article"
  publishedTime={publishedAt.toISOString()}
  modifiedTime={modifiedAt.toISOString()}
  tags={post.data.tags}
  jsonLd={jsonLd}
>
  <article>
    <div class={`article-layout${shouldShowToc ? ' article-layout-with-toc' : ''}`}>
      <div class="article-content">
        <header class="article-header">
          <p class="category">{post.data.category}</p>
          <p class="meta">{metaParts.join(' · ')}</p>
          <h1>{visibleHeadline}</h1>
          <p class="desc">{post.data.summary}</p>
        </header>

        {coverImageSrc && <img class="cover-image" src={coverImageSrc} alt={post.data.title} />}

        {shouldShowToc && (
          <details class="toc-mobile toc-mobile-only">
            <summary class="toc-mobile-summary">{ui.tableOfContents}</summary>
            <nav aria-label={ui.tableOfContents}>
              <ul class="toc-list">
                {tocH2Headings.map((heading) => (
                  <li class="toc-section">
                    <a class="toc-link toc-link-h2" data-toc-link data-target={heading.slug} href={`#${heading.slug}`}>
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </details>
        )}

        <section class="markdown-body article-main">
          <Content />
        </section>
      </div>

      {shouldShowToc && (
        <aside class="toc-card toc-desktop toc-desktop-only" aria-labelledby="toc-title-desktop">
          <p id="toc-title-desktop" class="toc-title">{ui.tableOfContents}</p>
          <nav aria-label={ui.tableOfContents}>
            <ul class="toc-list">
              {tocH2Headings.map((heading) => (
                <li class="toc-section">
                  <a class="toc-link toc-link-h2" data-toc-link data-target={heading.slug} href={`#${heading.slug}`}>
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}
    </div>
  </article>
</BaseLayout>

<script is:inline>
  (() => {
    const run = () => {
      const tableNodes = Array.from(document.querySelectorAll('.article-main table'));
      for (const table of tableNodes) {
        const parent = table.parentElement;
        if (parent && parent.classList.contains('table-scroll')) continue;
        const wrapper = document.createElement('div');
        wrapper.className = 'table-scroll';
        table.before(wrapper);
        wrapper.appendChild(table);
      }

      const headingNodes = Array.from(document.querySelectorAll('.article-main h2[id]'));
      const tocLinks = Array.from(document.querySelectorAll('[data-toc-link]'));
      if (!headingNodes.length || !tocLinks.length) return;

      const linksById = new Map();
      for (const link of tocLinks) {
        const id = link.getAttribute('data-target');
        if (!id) continue;
        const group = linksById.get(id) ?? [];
        group.push(link);
        linksById.set(id, group);
      }

      const setActive = (activeId) => {
        for (const link of tocLinks) {
          const target = link.getAttribute('data-target');
          const isActive = Boolean(activeId && target === activeId);
          link.classList.toggle('is-active', isActive);
          if (isActive) {
            link.setAttribute('aria-current', 'true');
          } else {
            link.removeAttribute('aria-current');
          }
        }
      };

      const hashId = decodeURIComponent(window.location.hash.replace('#', ''));
      if (hashId && linksById.has(hashId)) {
        setActive(hashId);
      } else if (headingNodes[0]) {
        setActive(headingNodes[0].id);
      }

      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            const visible = entries
              .filter((entry) => entry.isIntersecting)
              .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
            if (visible[0]) {
              setActive(visible[0].target.id);
            }
          },
          {
            rootMargin: '-24% 0px -62% 0px',
            threshold: [0, 1],
          },
        );

        for (const heading of headingNodes) {
          observer.observe(heading);
        }
      }

      window.addEventListener('hashchange', () => {
        const nextId = decodeURIComponent(window.location.hash.replace('#', ''));
        if (nextId && linksById.has(nextId)) {
          setActive(nextId);
        }
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run, { once: true });
    } else {
      run();
    }
  })();
</script>

<style>
  .article-header {
    background: #ffffff;
    border: 1px solid #dbe5ef;
    border-radius: 1rem;
    padding: 1rem 1rem 0.8rem;
    margin-bottom: 1.2rem;
  }

  .meta {
    margin: 0;
    color: #64748b;
    font-size: 0.92rem;
  }

  .category {
    margin: 0 0 0.35rem;
    color: #0f766e;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .desc {
    margin-bottom: 0;
    color: #334155;
  }

  .cover-image {
    display: block;
    width: 100%;
    max-height: 420px;
    border: 1px solid #dbe5ef;
    border-radius: 1rem;
    background: #ffffff;
    margin-bottom: 1.2rem;
    object-fit: cover;
  }

  article {
    max-width: 100%;
  }

  .article-layout {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  .article-content {
    min-width: 0;
  }

  .article-main {
    min-width: 0;
  }

  .markdown-body {
    background: #ffffff;
    border: 1px solid #dbe5ef;
    border-radius: 1rem;
    padding: 1rem;
  }

  :global(.markdown-body .table-scroll) {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  :global(.markdown-body table) {
    width: 100%;
    table-layout: auto;
  }

  :global(.markdown-body .table-scroll > table) {
    width: max-content;
    min-width: 100%;
  }

  :global(.markdown-body th),
  :global(.markdown-body td) {
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  :global(.markdown-body th + th),
  :global(.markdown-body td + td) {
    border-left: 1px solid #e2e8f0;
  }

  .toc-mobile {
    background: #f8fafc;
    border: 1px solid #dbe5ef;
    border-radius: 1rem;
  }

  :global(.toc-mobile-only) {
    display: block;
  }

  .toc-mobile-summary {
    list-style: none;
    cursor: pointer;
    padding: 0.88rem 0.9rem;
    margin: 0;
    color: #334155;
    font-size: 0.95rem;
    font-weight: 700;
  }

  .toc-mobile-summary::-webkit-details-marker {
    display: none;
  }

  .toc-mobile-summary::after {
    content: '+';
    float: right;
    color: #0f766e;
  }

  .toc-mobile[open] .toc-mobile-summary::after {
    content: '-';
  }

  .toc-mobile nav {
    padding: 0 0.9rem 0.9rem;
  }

  .toc-card {
    background: #f8fafc;
    border: 1px solid #dbe5ef;
    border-radius: 1rem;
    padding: 0.92rem 0.9rem;
    box-shadow: 0 6px 18px -20px rgba(15, 23, 42, 0.8);
  }

  .toc-desktop {
    width: 100%;
  }

  :global(.toc-desktop-only) {
    display: none;
  }

  .toc-title {
    margin: 0 0 0.72rem;
    color: #334155;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.45rem;
  }

  .toc-section {
    margin: 0;
    padding-bottom: 0.45rem;
    border-bottom: 1px dashed #e2e8f0;
  }

  .toc-section:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .toc-link {
    text-decoration: none;
    display: inline-block;
  }

  .toc-link-h2 {
    color: #475569;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.45;
  }

  .toc-link:hover,
  .toc-link:focus-visible {
    color: #0f766e;
  }

  .toc-link.is-active,
  .toc-link[aria-current='true'] {
    color: #0f766e;
    font-weight: 700;
  }

  :global(.markdown-body h2) {
    scroll-margin-top: 6.5rem;
  }

  @media (prefers-reduced-motion: no-preference) {
    :global(html) {
      scroll-behavior: smooth;
    }
  }

  @media (max-width: 980px) {
    :global(.markdown-body table) {
      display: block;
      width: max-content;
      min-width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    :global(.markdown-body .table-scroll > table) {
      display: table;
      width: max-content;
      min-width: 100%;
    }

    :global(.markdown-body th),
    :global(.markdown-body td) {
      white-space: nowrap;
      overflow-wrap: normal;
      word-break: normal;
    }
  }

  @media (min-width: 980px) {
    :global(main.container.content) {
      --container-max: 1240px;
      --container-vw: 94vw;
    }

    .article-layout-with-toc {
      --article-toc-width: 290px;
      --article-toc-gap: 1.5rem;
      grid-template-columns: minmax(0, 1fr) var(--article-toc-width);
      column-gap: var(--article-toc-gap);
    }

    .article-layout-with-toc > .article-content {
      grid-column: 1;
      min-width: 0;
    }

    :global(.toc-mobile-only) {
      display: none !important;
    }

    .article-layout-with-toc > .toc-desktop-only {
      grid-column: 2;
      align-self: start;
      width: 100%;
      display: block !important;
      position: sticky;
      top: 6.4rem;
      max-height: calc(100vh - 7.2rem);
      overflow: auto;
      overscroll-behavior: contain;
    }
  }
</style>
