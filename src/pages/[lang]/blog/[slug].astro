---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostComments from '../../../components/PostComments.astro';
import PostCardList from '../../../components/PostCardList.astro';
import TopOfferCard from '../../../components/TopOfferCard.astro';
import { getSponsorCtaCopy } from '../../../lib/sponsorCtaCopy';
import {
  DEFAULT_LANG,
  collectSiteLangs,
  getLangLabel,
  getLocaleCode,
  getSiteName,
  getUi,
  type Lang,
} from '../../../lib/i18n';

type TranslationRef = { lang: Lang; slug: string };

export async function getStaticPaths() {
  const MAX_RELATED_POSTS = 4;
  const getPostSlug = (id: string) => id.split('/').pop() ?? id;
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const byTranslation = new Map<string, CollectionEntry<'blog'>[]>();

  for (const post of posts) {
    const key = post.data.translationKey;
    byTranslation.set(key, [...(byTranslation.get(key) ?? []), post]);
  }

  return posts.map((post) => {
    const translations = (byTranslation.get(post.data.translationKey) ?? []).map((item) => ({
      lang: item.data.locale,
      slug: getPostSlug(item.id),
    }));
    const relatedPosts = Array.from(new Set(post.data.relatedTranslationKeys))
      .filter((translationKey) => translationKey !== post.data.translationKey)
      .map((translationKey) => {
        const candidates = byTranslation.get(translationKey) ?? [];
        return candidates.find((candidate) => candidate.data.locale === post.data.locale);
      })
      .filter((item): item is CollectionEntry<'blog'> => Boolean(item))
      .slice(0, MAX_RELATED_POSTS);

    return {
      params: { lang: post.data.locale, slug: getPostSlug(post.id) },
      props: { post, translations, relatedPosts },
    };
  });
}

interface Props {
  post: CollectionEntry<'blog'>;
  translations: TranslationRef[];
  relatedPosts: CollectionEntry<'blog'>[];
}

const { post, translations, relatedPosts } = Astro.props as Props;
const currentLang = post.data.locale;
const ui = getUi(currentLang);
const localeCode = getLocaleCode(currentLang);
const siteName = getSiteName(currentLang);
const visibleHeadline = post.data.headline ?? post.data.title;
const translationLangs = collectSiteLangs(translations.map((item) => item.lang));
const { Content, headings } = await render(post);
const tocH2Headings = headings.filter(
  (heading) => heading.depth === 2 && heading.text.trim().length > 0 && heading.slug.trim().length > 0,
);
const MIN_TOC_H2_COUNT = 3;
const shouldShowToc = tocH2Headings.length >= MIN_TOC_H2_COUNT;
const getPostSlug = (id: string) => id.split('/').pop() ?? id;
const publishedAt = post.data.pubDate;
const modifiedAt = post.data.updatedDate ?? publishedAt;
const publishedDateText = publishedAt.toISOString().slice(0, 10);
const modifiedDateText = modifiedAt.toISOString().slice(0, 10);
const showUpdatedDate = modifiedAt.getTime() > publishedAt.getTime();
const metaParts = [`${ui.publishedLabel} ${publishedDateText}`];
if (showUpdatedDate) {
  metaParts.push(`${ui.updatedLabel} ${modifiedDateText}`);
}
metaParts.push(post.data.service);
metaParts.push(`${ui.articleBy} ${post.data.author}`);

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
const siteBase = Astro.site ?? new URL(Astro.url.origin);
const toCoverImageSrc = (src?: string) =>
  src ? (/^https?:\/\//.test(src) ? src : `${baseUrl}${src.replace(/^\/+/, '')}`) : undefined;
const currentSlug = getPostSlug(post.id);
const canonical = new URL(`${baseUrl}${currentLang}/blog/${currentSlug}/`, siteBase).toString();
const coverImageSrc = toCoverImageSrc(post.data.coverImage);
const relatedItems = relatedPosts.map((relatedPost) => {
  const relatedPublishedAt = relatedPost.data.pubDate;
  const relatedModifiedAt = relatedPost.data.updatedDate ?? relatedPublishedAt;
  const relatedPublishedDateText = relatedPublishedAt.toISOString().slice(0, 10);
  const relatedModifiedDateText = relatedModifiedAt.toISOString().slice(0, 10);
  const showRelatedUpdatedDate = relatedModifiedAt.getTime() > relatedPublishedAt.getTime();
  const relatedMetaParts = [`${ui.publishedLabel} ${relatedPublishedDateText}`];
  if (showRelatedUpdatedDate) {
    relatedMetaParts.push(`${ui.updatedLabel} ${relatedModifiedDateText}`);
  }
  relatedMetaParts.push(relatedPost.data.service);
  if (relatedPost.data.tags.length > 0) {
    relatedMetaParts.push(relatedPost.data.tags.join(' / '));
  }

  return {
    href: `${baseUrl}${currentLang}/blog/${getPostSlug(relatedPost.id)}/`,
    title: relatedPost.data.title,
    summary: relatedPost.data.summary,
    category: relatedPost.data.category,
    coverImageSrc: toCoverImageSrc(relatedPost.data.coverImage),
    meta: relatedMetaParts.join(' · '),
  };
});

const alternates = translations.map((item) => ({
  hrefLang: getLocaleCode(item.lang),
  href: new URL(`${baseUrl}${item.lang}/blog/${item.slug}/`, siteBase).toString(),
}));

const defaultTranslation = translations.find((item) => item.lang === DEFAULT_LANG) ?? translations[0];
if (defaultTranslation) {
  alternates.push({
    hrefLang: 'x-default',
    href: new URL(`${baseUrl}${defaultTranslation.lang}/blog/${defaultTranslation.slug}/`, siteBase).toString(),
  });
}

const languageLinks = translationLangs.map((lang) => {
  const hit = translations.find((item) => item.lang === lang);
  return {
    label: getLangLabel(lang),
    href: hit ? `${baseUrl}${lang}/blog/${hit.slug}/` : `${baseUrl}${currentLang}/blog/${currentSlug}/`,
    active: lang === currentLang,
  };
});

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: visibleHeadline,
  description: post.data.description,
  datePublished: publishedAt.toISOString(),
  dateModified: modifiedAt.toISOString(),
  inLanguage: localeCode,
  author: {
    '@type': 'Person',
    name: post.data.author,
  },
  mainEntityOfPage: canonical,
};

const topOffer = post.data.topOffer;
const sponsorCta = getSponsorCtaCopy(currentLang);
const sponsorRel = 'nofollow sponsored noopener noreferrer';
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={canonical}
  lang={currentLang}
  localeCode={localeCode}
  siteName={siteName}
  homeLabel={ui.home}
  blogLabel={ui.blog}
  footerText={ui.footer}
  navHomeHref={`${baseUrl}${currentLang}/`}
  navBlogHref={`${baseUrl}${currentLang}/blog/`}
  languageLabel={ui.languageSwitch}
  languageLinks={languageLinks}
  alternates={alternates}
  image={coverImageSrc}
  type="article"
  publishedTime={publishedAt.toISOString()}
  modifiedTime={modifiedAt.toISOString()}
  tags={post.data.tags}
  jsonLd={jsonLd}
>
  <article>
    <div class={`article-layout${shouldShowToc ? ' article-layout-with-toc' : ''}`}>
      <div class="article-content">
        <header class="article-header">
          <p class="category">{post.data.category}</p>
          <p class="meta">{metaParts.join(' · ')}</p>
          <h1>{visibleHeadline}</h1>
          <p class="desc">{post.data.summary}</p>
        </header>

        {topOffer && (
          <TopOfferCard
            title={topOffer.title}
            subtitle={topOffer.subtitle}
            buttonText={topOffer.buttonText}
            buttonLink={topOffer.buttonLink}
          />
        )}

        {coverImageSrc && <img class="cover-image" src={coverImageSrc} alt={post.data.title} />}

        {shouldShowToc && (
          <details class="toc-mobile toc-mobile-only">
            <summary class="toc-mobile-summary">{ui.tableOfContents}</summary>
            <nav aria-label={ui.tableOfContents}>
              <ul class="toc-list">
                {tocH2Headings.map((heading) => (
                  <li class="toc-section">
                    <a class="toc-link toc-link-h2" data-toc-link data-target={heading.slug} href={`#${heading.slug}`}>
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
              <div class="toc-sponsor-wrap">
                <a class="toc-sponsor" href={sponsorCta.href} target="_blank" rel={sponsorRel} aria-label={sponsorCta.tocAriaLabel}>
                  <span class="toc-sponsor-copy">{sponsorCta.tocTitle}</span>
                  <span class="toc-sponsor-button">
                    <span>{sponsorCta.tocButtonText}</span>
                    <span class="toc-sponsor-arrow" aria-hidden="true">→</span>
                  </span>
                </a>
              </div>
            </nav>
          </details>
        )}

        <section class="markdown-body article-main">
          <Content />
        </section>

        {relatedItems.length > 0 && (
          <section class="related-posts" aria-labelledby="related-posts-title">
            <h2 id="related-posts-title" class="related-posts-title">{ui.relatedPosts}</h2>
            <PostCardList items={relatedItems} titleTag="h3" />
          </section>
        )}

        <PostComments term={post.data.translationKey} lang={currentLang} />
      </div>

      {shouldShowToc && (
        <aside class="toc-card toc-desktop toc-desktop-only" aria-labelledby="toc-title-desktop">
          <p id="toc-title-desktop" class="toc-title">{ui.tableOfContents}</p>
          <nav aria-label={ui.tableOfContents}>
            <ul class="toc-list">
              {tocH2Headings.map((heading) => (
                <li class="toc-section">
                  <a class="toc-link toc-link-h2" data-toc-link data-target={heading.slug} href={`#${heading.slug}`}>
                    {heading.text}
                  </a>
                </li>
                ))}
              </ul>
            </nav>
            <div class="toc-sponsor-wrap">
              <a class="toc-sponsor" href={sponsorCta.href} target="_blank" rel={sponsorRel} aria-label={sponsorCta.tocAriaLabel}>
                <span class="toc-sponsor-copy">{sponsorCta.tocTitle}</span>
                <span class="toc-sponsor-button">
                  <span>{sponsorCta.tocButtonText}</span>
                  <span class="toc-sponsor-arrow" aria-hidden="true">→</span>
                </span>
              </a>
            </div>
        </aside>
      )}
    </div>
  </article>
</BaseLayout>

<script is:inline>
  (() => {
    const run = () => {
      const tableNodes = Array.from(document.querySelectorAll('.article-main table'));
      for (const table of tableNodes) {
        const parent = table.parentElement;
        if (parent && parent.classList.contains('table-scroll')) continue;
        const wrapper = document.createElement('div');
        wrapper.className = 'table-scroll';
        table.before(wrapper);
        wrapper.appendChild(table);
      }

      const headingNodes = Array.from(document.querySelectorAll('.article-main h2[id]'));
      const tocLinks = Array.from(document.querySelectorAll('[data-toc-link]'));
      if (!headingNodes.length || !tocLinks.length) return;

      const linksById = new Map();
      for (const link of tocLinks) {
        const id = link.getAttribute('data-target');
        if (!id) continue;
        const group = linksById.get(id) ?? [];
        group.push(link);
        linksById.set(id, group);
      }

      const setActive = (activeId) => {
        for (const link of tocLinks) {
          const target = link.getAttribute('data-target');
          const isActive = Boolean(activeId && target === activeId);
          link.classList.toggle('is-active', isActive);
          if (isActive) {
            link.setAttribute('aria-current', 'true');
          } else {
            link.removeAttribute('aria-current');
          }
        }
      };

      const hashId = decodeURIComponent(window.location.hash.replace('#', ''));
      if (hashId && linksById.has(hashId)) {
        setActive(hashId);
      } else if (headingNodes[0]) {
        setActive(headingNodes[0].id);
      }

      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            const visible = entries
              .filter((entry) => entry.isIntersecting)
              .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
            if (visible[0]) {
              setActive(visible[0].target.id);
            }
          },
          {
            rootMargin: '-24% 0px -62% 0px',
            threshold: [0, 1],
          },
        );

        for (const heading of headingNodes) {
          observer.observe(heading);
        }
      }

      window.addEventListener('hashchange', () => {
        const nextId = decodeURIComponent(window.location.hash.replace('#', ''));
        if (nextId && linksById.has(nextId)) {
          setActive(nextId);
        }
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run, { once: true });
    } else {
      run();
    }
  })();
</script>

<style>
  .article-header {
    background:
      linear-gradient(180deg, rgba(236, 254, 255, 0.68) 0%, rgba(255, 255, 255, 0.96) 54%, #ffffff 100%),
      repeating-linear-gradient(90deg, transparent 0, transparent 22px, rgba(15, 23, 42, 0.017) 22px, rgba(15, 23, 42, 0.017) 23px);
    border: 1px solid var(--line);
    border-radius: 1rem;
    padding: 1.1rem 1rem 0.95rem;
    margin-bottom: 1rem;
    box-shadow: var(--shadow-card);
  }

  .meta {
    margin: 0;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .category {
    margin: 0 0 0.35rem;
    color: #0f766e;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .desc {
    margin-bottom: 0;
    color: var(--text-soft);
  }

  .cover-image {
    display: block;
    width: 100%;
    max-height: 420px;
    border: 1px solid var(--line);
    border-radius: 1rem;
    background: var(--card);
    margin-bottom: 1rem;
    box-shadow: var(--shadow-card);
    object-fit: cover;
  }

  article {
    max-width: 100%;
  }

  .article-layout {
    display: grid;
    gap: 1.02rem;
    align-items: start;
  }

  .article-content {
    min-width: 0;
  }

  .article-main {
    min-width: 0;
  }

  .markdown-body {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 1rem;
    padding: 1.02rem;
    box-shadow: var(--shadow-card);
  }

  :global(.markdown-body > :first-child) {
    margin-top: 0;
  }

  :global(.markdown-body > :last-child) {
    margin-bottom: 0;
  }

  :global(.markdown-body p),
  :global(.markdown-body li),
  :global(.markdown-body blockquote) {
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  :global(.markdown-body h2) {
    margin-top: 1.7rem;
    scroll-margin-top: 6.2rem;
  }

  :global(.markdown-body h3) {
    margin-top: 1.1rem;
  }

  :global(.markdown-body pre) {
    max-width: 100%;
    overflow-x: auto;
  }

  .related-posts {
    margin-top: 1.15rem;
  }

  .related-posts-title {
    margin: 0 0 0.74rem;
  }

  :global(.markdown-body .table-scroll) {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  :global(.markdown-body table) {
    width: 100%;
    table-layout: auto;
  }

  :global(.markdown-body .table-scroll > table) {
    width: max-content;
    min-width: 100%;
  }

  :global(.markdown-body th),
  :global(.markdown-body td) {
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  :global(.markdown-body th + th),
  :global(.markdown-body td + td) {
    border-left: 1px solid var(--line);
  }

  .toc-mobile {
    background: var(--card-muted);
    border: 1px solid var(--line);
    border-radius: 1rem;
    box-shadow: var(--shadow-card);
  }

  :global(.toc-mobile-only) {
    display: block;
  }

  .toc-mobile-summary {
    list-style: none;
    cursor: pointer;
    padding: 0.88rem 0.9rem;
    margin: 0;
    color: var(--text-soft);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .toc-mobile-summary::-webkit-details-marker {
    display: none;
  }

  .toc-mobile-summary::after {
    content: '+';
    float: right;
    color: #0f766e;
  }

  .toc-mobile[open] .toc-mobile-summary::after {
    content: '-';
  }

  .toc-mobile nav {
    padding: 0 0.9rem 0.9rem;
  }

  .toc-card {
    background: var(--card-muted);
    border: 1px solid var(--line);
    border-radius: 1rem;
    padding: 0.92rem 0.9rem;
    box-shadow: var(--shadow-card);
  }

  .toc-desktop {
    width: 100%;
  }

  :global(.toc-desktop-only) {
    display: none;
  }

  .toc-title {
    margin: 0 0 0.72rem;
    color: var(--text-soft);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.45rem;
  }

  .toc-section {
    margin: 0;
    padding-bottom: 0.45rem;
    border-bottom: 1px dashed var(--line);
  }

  .toc-section:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .toc-link {
    text-decoration: none;
    display: inline-block;
  }

  .toc-link-h2 {
    color: var(--muted);
    font-size: 0.86rem;
    font-weight: 600;
    line-height: 1.42;
  }

  .toc-link:hover,
  .toc-link:focus-visible {
    color: #0f766e;
  }

  .toc-link.is-active,
  .toc-link[aria-current='true'] {
    color: #0f766e;
    font-weight: 700;
  }

  .toc-sponsor-wrap {
    margin-top: 0.95rem;
    padding-top: 0.78rem;
    border-top: 1px dashed var(--line);
  }

  .toc-sponsor {
    display: grid;
    gap: 0.58rem;
    text-decoration: none;
    border: 1px solid #99f6e4;
    border-radius: 0.96rem;
    padding: 0.78rem 0.78rem 0.74rem;
    background:
      radial-gradient(circle at 102% -6%, rgba(14, 116, 144, 0.18) 0%, rgba(14, 116, 144, 0) 46%),
      linear-gradient(180deg, #f0fdfa 0%, #ecfeff 100%);
    box-shadow: 0 12px 26px -22px rgba(15, 118, 110, 0.54);
    backface-visibility: hidden;
    transform: translateZ(0);
    transition: border-color 140ms ease, box-shadow 140ms ease, transform 140ms ease;
  }

  .toc-sponsor-copy {
    color: var(--text);
    font-size: 0.84rem;
    font-weight: 800;
    line-height: 1.4;
    letter-spacing: 0.01em;
  }

  .toc-sponsor-button {
    justify-self: start;
    display: inline-flex;
    align-items: center;
    gap: 0.34rem;
    color: #ffffff;
    background: #0f766e;
    border: 1px solid #0f766e;
    border-radius: 999px;
    padding: 0.35rem 0.68rem;
    font-size: 0.76rem;
    font-weight: 700;
    line-height: 1.2;
    white-space: nowrap;
    box-shadow: 0 8px 16px -14px rgba(15, 118, 110, 0.86);
    transition: background-color 140ms ease, border-color 140ms ease;
  }

  .toc-sponsor-arrow {
    line-height: 1;
  }

  .toc-sponsor:hover,
  .toc-sponsor:focus-visible {
    border-color: #5eead4;
    box-shadow: 0 16px 30px -22px rgba(15, 118, 110, 0.66);
    transform: translateY(-1px);
  }

  .toc-sponsor:hover .toc-sponsor-button,
  .toc-sponsor:focus-visible .toc-sponsor-button {
    background: #115e59;
    border-color: #115e59;
  }

  @media (prefers-reduced-motion: reduce) {
    .toc-sponsor,
    .toc-sponsor-button {
      transition: none;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    :global(html) {
      scroll-behavior: smooth;
    }
  }

  @media (max-width: 980px) {
    :global(.markdown-body table) {
      display: block;
      width: max-content;
      min-width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    :global(.markdown-body .table-scroll > table) {
      display: table;
      width: max-content;
      min-width: 100%;
    }

    :global(.markdown-body th),
    :global(.markdown-body td) {
      white-space: nowrap;
      overflow-wrap: normal;
      word-break: normal;
    }
  }

  @media (min-width: 1260px) {
    .article-layout-with-toc {
      grid-template-columns: minmax(0, 1fr) 272px;
      gap: 1.2rem;
    }

    .article-layout-with-toc > .article-content {
      min-width: 0;
    }

    :global(.toc-mobile-only) {
      display: none !important;
    }

    .article-layout-with-toc > .toc-desktop-only {
      display: block !important;
      position: sticky;
      top: 5.9rem;
      width: 100%;
      max-height: calc(100vh - 6.7rem);
      overflow: auto;
      overscroll-behavior: contain;
      align-self: start;
    }
  }
</style>
