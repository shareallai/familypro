---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  DEFAULT_LANG,
  collectSiteLangs,
  getLangLabel,
  getLocaleCode,
  getSiteName,
  getUi,
  type Lang,
} from '../../../lib/i18n';

type TranslationRef = { lang: Lang; slug: string };

export async function getStaticPaths() {
  const getPostSlug = (id: string) => id.split('/').pop() ?? id;
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const siteLangs = collectSiteLangs(posts.map((post) => post.data.locale));
  const byTranslation = new Map<string, CollectionEntry<'blog'>[]>();

  for (const post of posts) {
    const key = post.data.translationKey;
    byTranslation.set(key, [...(byTranslation.get(key) ?? []), post]);
  }

  return posts.map((post) => {
    const translations = (byTranslation.get(post.data.translationKey) ?? []).map((item) => ({
      lang: item.data.locale,
      slug: getPostSlug(item.id),
    }));

    return {
      params: { lang: post.data.locale, slug: getPostSlug(post.id) },
      props: { post, translations, siteLangs },
    };
  });
}

interface Props {
  post: CollectionEntry<'blog'>;
  translations: TranslationRef[];
  siteLangs: Lang[];
}

const { post, translations, siteLangs } = Astro.props as Props;
const currentLang = post.data.locale;
const ui = getUi(currentLang);
const localeCode = getLocaleCode(currentLang);
const siteName = getSiteName(currentLang);
const activeLangs = collectSiteLangs(siteLangs);
const { Content } = await render(post);
const getPostSlug = (id: string) => id.split('/').pop() ?? id;

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
const siteBase = Astro.site ?? new URL(Astro.url.origin);
const currentSlug = getPostSlug(post.id);
const canonical = new URL(`${baseUrl}${currentLang}/blog/${currentSlug}/`, siteBase).toString();

const alternates = translations.map((item) => ({
  hrefLang: getLocaleCode(item.lang),
  href: new URL(`${baseUrl}${item.lang}/blog/${item.slug}/`, siteBase).toString(),
}));

const defaultTranslation = translations.find((item) => item.lang === DEFAULT_LANG) ?? translations[0];
if (defaultTranslation) {
  alternates.push({
    hrefLang: 'x-default',
    href: new URL(`${baseUrl}${defaultTranslation.lang}/blog/${defaultTranslation.slug}/`, siteBase).toString(),
  });
}

const languageLinks = activeLangs.map((lang) => {
  const hit = translations.find((item) => item.lang === lang);
  return {
    label: getLangLabel(lang),
    href: hit ? `${baseUrl}${lang}/blog/${hit.slug}/` : `${baseUrl}${lang}/blog/`,
    active: lang === currentLang,
  };
});

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  inLanguage: localeCode,
  author: {
    '@type': 'Person',
    name: post.data.author,
  },
  mainEntityOfPage: canonical,
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={canonical}
  lang={currentLang}
  localeCode={localeCode}
  siteName={siteName}
  homeLabel={ui.home}
  blogLabel={ui.blog}
  footerText={ui.footer}
  navHomeHref={`${baseUrl}${currentLang}/`}
  navBlogHref={`${baseUrl}${currentLang}/blog/`}
  languageLabel={ui.languageSwitch}
  languageLinks={languageLinks}
  alternates={alternates}
  type="article"
  publishedTime={post.data.pubDate.toISOString()}
  modifiedTime={(post.data.updatedDate ?? post.data.pubDate).toISOString()}
  tags={post.data.tags}
  jsonLd={jsonLd}
>
  <article>
    <header class="article-header">
      <p class="meta">
        {post.data.pubDate.toISOString().slice(0, 10)} · {post.data.service} · {ui.articleBy} {post.data.author}
      </p>
      <h1>{post.data.title}</h1>
      <p class="desc">{post.data.description}</p>
    </header>

    <section class="price-table-wrap">
      <h2>{post.data.tableLabels.title}</h2>
      <p class="muted">{post.data.exchangeRateNote}</p>
      <table>
        <thead>
          <tr>
            <th>{post.data.tableLabels.country}</th>
            <th>{post.data.tableLabels.currency}</th>
            <th>{post.data.tableLabels.price}</th>
            <th>{post.data.tableLabels.usd}</th>
            <th>{post.data.tableLabels.notes}</th>
          </tr>
        </thead>
        <tbody>
          {post.data.priceRows.map((row) => (
            <tr>
              <td>{row.country}</td>
              <td>{row.currency}</td>
              <td>{row.officialMonthly}</td>
              <td>${row.usdApprox.toFixed(2)}</td>
              <td>{row.notes ?? '-'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="markdown-body">
      <Content />
    </section>
  </article>
</BaseLayout>

<style>
  .article-header {
    background: #ffffff;
    border: 1px solid #dbe5ef;
    border-radius: 1rem;
    padding: 1rem 1rem 0.8rem;
    margin-bottom: 1.2rem;
  }

  .meta {
    margin: 0;
    color: #64748b;
    font-size: 0.92rem;
  }

  .desc {
    margin-bottom: 0;
    color: #334155;
  }

  .price-table-wrap {
    background: #ffffff;
    border: 1px solid #dbe5ef;
    border-radius: 1rem;
    padding: 1rem;
    margin-bottom: 1.2rem;
  }

  .muted {
    color: #64748b;
    margin-top: -0.3rem;
  }

  .markdown-body {
    background: #ffffff;
    border: 1px solid #dbe5ef;
    border-radius: 1rem;
    padding: 1rem;
  }
</style>
