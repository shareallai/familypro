---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  DEFAULT_LANG,
  buildHomeTitle,
  collectSiteLangs,
  getLangLabel,
  getLocaleCode,
  getSiteName,
  getUi,
  type Lang,
} from '../../lib/i18n';

interface Props {
  siteLangs: Lang[];
}

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const siteLangs = collectSiteLangs(posts.map((post) => post.data.locale));
  return siteLangs.map((lang) => ({ params: { lang }, props: { siteLangs } }));
}

const { siteLangs } = Astro.props as Props;
const lang = (Astro.params.lang ?? DEFAULT_LANG).toLowerCase();
const activeLangs = collectSiteLangs(siteLangs);
if (!activeLangs.includes(lang)) {
  throw new Error(`Unsupported language: ${lang}`);
}

const ui = getUi(lang);
const siteName = getSiteName(lang);
const localeCode = getLocaleCode(lang);

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.locale === lang)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const postCards = posts.map((post) => {
  const publishedAt = post.data.pubDate;
  const modifiedAt = post.data.updatedDate ?? publishedAt;
  return {
    post,
    publishedDateText: publishedAt.toISOString().slice(0, 10),
    modifiedDateText: modifiedAt.toISOString().slice(0, 10),
    showUpdatedDate: modifiedAt.getTime() > publishedAt.getTime(),
  };
});

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
const siteBase = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(`${baseUrl}${lang}/`, siteBase).toString();

const alternates = activeLangs.map((code) => ({
  hrefLang: getLocaleCode(code),
  href: new URL(`${baseUrl}${code}/`, siteBase).toString(),
}));
alternates.push({ hrefLang: 'x-default', href: new URL(`${baseUrl}${DEFAULT_LANG}/`, siteBase).toString() });

const languageLinks = activeLangs.map((code) => ({
  label: getLangLabel(code),
  href: `${baseUrl}${code}/`,
  active: code === lang,
}));

const title = buildHomeTitle(lang, siteName);
const description = ui.heroDesc;
const getCoverImageSrc = (src?: string) => (src ? (/^https?:\/\//.test(src) ? src : `${baseUrl}${src.replace(/^\/+/, '')}`) : undefined);

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: canonical,
  inLanguage: localeCode,
  description,
};

const getPostSlug = (id: string) => id.split('/').pop() ?? id;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lang={lang}
  localeCode={localeCode}
  siteName={siteName}
  homeLabel={ui.home}
  blogLabel={ui.blog}
  footerText={ui.footer}
  navHomeHref={`${baseUrl}${lang}/`}
  navBlogHref={`${baseUrl}${lang}/blog/`}
  languageLabel={ui.languageSwitch}
  languageLinks={languageLinks}
  alternates={alternates}
  jsonLd={websiteJsonLd}
>
  <section class="hero">
    <p class="eyebrow">{ui.heroEyebrow}</p>
    <h1>{ui.heroTitle}</h1>
    <p>{ui.heroDesc}</p>
  </section>

  <section>
    <h2>{ui.latestPosts}</h2>
    {postCards.length === 0 ? (
      <p>{ui.noPosts}</p>
    ) : (
      <ul class="post-list">
        {postCards.map(({ post, publishedDateText, modifiedDateText, showUpdatedDate }) => (
          <li class="card">
            <a href={`${baseUrl}${lang}/blog/${getPostSlug(post.id)}/`} data-astro-prefetch="viewport">
              {getCoverImageSrc(post.data.coverImage) && (
                <img class="card-cover" src={getCoverImageSrc(post.data.coverImage)} alt={post.data.title} />
              )}
              <p class="card-category">{post.data.category}</p>
              <h3>{post.data.title}</h3>
            </a>
            <p>{post.data.summary}</p>
            <p class="meta">
              {ui.publishedLabel} {publishedDateText}
              {showUpdatedDate && ` · ${ui.updatedLabel} ${modifiedDateText}`} · {post.data.tags.join(' / ')}
            </p>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .hero {
    background: #ffffff;
    border: 1px solid #dbe5ef;
    border-radius: 1rem;
    padding: 1.2rem 1.2rem 1.1rem;
    box-shadow: 0 6px 20px rgba(15, 23, 42, 0.06);
    margin-bottom: 1.5rem;
  }

  .eyebrow {
    margin: 0;
    color: #0f766e;
    font-weight: 700;
    font-size: 0.88rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .card {
    background: #ffffff;
    border: 1px solid #dbe5ef;
    border-radius: 0.9rem;
    padding: 1rem 1rem 0.8rem;
  }

  .card-cover {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    max-height: 180px;
    border-radius: 0.7rem;
    border: 1px solid #dbe5ef;
    margin-bottom: 0.85rem;
    object-fit: cover;
  }

  .card-category {
    margin: 0 0 0.25rem;
    color: #0f766e;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .card h3 {
    margin-top: 0;
    margin-bottom: 0.4rem;
  }

  .card p {
    margin: 0.3rem 0;
  }

  .meta {
    color: #64748b;
    font-size: 0.9rem;
  }
</style>
