---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCardList from '../../components/PostCardList.astro';
import {
  DEFAULT_LANG,
  buildHomeTitle,
  collectSiteLangs,
  getLangLabel,
  getLocaleCode,
  getSiteName,
  getUi,
  type Lang,
} from '../../lib/i18n';

interface Props {
  siteLangs: Lang[];
}

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const siteLangs = collectSiteLangs(posts.map((post) => post.data.locale));
  return siteLangs.map((lang) => ({ params: { lang }, props: { siteLangs } }));
}

const { siteLangs } = Astro.props as Props;
const lang = (Astro.params.lang ?? DEFAULT_LANG).toLowerCase();
const activeLangs = collectSiteLangs(siteLangs);
if (!activeLangs.includes(lang)) {
  throw new Error(`Unsupported language: ${lang}`);
}

const ui = getUi(lang);
const siteName = getSiteName(lang);
const localeCode = getLocaleCode(lang);

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.locale === lang)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
const siteBase = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(`${baseUrl}${lang}/`, siteBase).toString();

const alternates = activeLangs.map((code) => ({
  hrefLang: getLocaleCode(code),
  href: new URL(`${baseUrl}${code}/`, siteBase).toString(),
}));
alternates.push({ hrefLang: 'x-default', href: new URL(`${baseUrl}${DEFAULT_LANG}/`, siteBase).toString() });

const languageLinks = activeLangs.map((code) => ({
  label: getLangLabel(code),
  href: `${baseUrl}${code}/`,
  active: code === lang,
}));

const title = buildHomeTitle(lang, siteName);
const description = ui.heroDesc;
const getCoverImageSrc = (src?: string) => (src ? (/^https?:\/\//.test(src) ? src : `${baseUrl}${src.replace(/^\/+/, '')}`) : undefined);

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: canonical,
  inLanguage: localeCode,
  description,
};

const getPostSlug = (id: string) => id.split('/').pop() ?? id;
const listItems = posts.map((post) => {
  const publishedAt = post.data.pubDate;
  const modifiedAt = post.data.updatedDate ?? publishedAt;
  const publishedDateText = publishedAt.toISOString().slice(0, 10);
  const modifiedDateText = modifiedAt.toISOString().slice(0, 10);
  const showUpdatedDate = modifiedAt.getTime() > publishedAt.getTime();
  return {
    href: `${baseUrl}${lang}/blog/${getPostSlug(post.id)}/`,
    title: post.data.title,
    summary: post.data.summary,
    category: post.data.category,
    coverImageSrc: getCoverImageSrc(post.data.coverImage),
    meta: `${ui.publishedLabel} ${publishedDateText}${showUpdatedDate ? ` · ${ui.updatedLabel} ${modifiedDateText}` : ''} · ${post.data.tags.join(' / ')}`,
  };
});
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lang={lang}
  localeCode={localeCode}
  siteName={siteName}
  homeLabel={ui.home}
  blogLabel={ui.blog}
  footerText={ui.footer}
  navHomeHref={`${baseUrl}${lang}/`}
  navBlogHref={`${baseUrl}${lang}/blog/`}
  languageLabel={ui.languageSwitch}
  languageLinks={languageLinks}
  alternates={alternates}
  jsonLd={websiteJsonLd}
>
  <section class="hero">
    <p class="eyebrow">{ui.heroEyebrow}</p>
    <h1>{ui.heroTitle}</h1>
    <p class="hero-desc">{ui.heroDesc}</p>
  </section>

  <section class="list-section">
    <h2 class="list-title">{ui.latestPosts}</h2>
    {listItems.length === 0 ? (
      <p>{ui.noPosts}</p>
    ) : (
      <PostCardList items={listItems} titleTag="h3" />
    )}
  </section>
</BaseLayout>

<style>
  .hero {
    background:
      linear-gradient(180deg, rgba(236, 254, 255, 0.68) 0%, rgba(255, 255, 255, 0.92) 48%, #ffffff 100%),
      repeating-linear-gradient(90deg, transparent 0, transparent 22px, rgba(15, 23, 42, 0.018) 22px, rgba(15, 23, 42, 0.018) 23px);
    border: 1px solid var(--line);
    border-radius: 1rem;
    padding: 1.3rem 1.2rem 1.18rem;
    box-shadow: var(--shadow-card);
    margin-bottom: 1.4rem;
  }

  .eyebrow {
    margin: 0;
    color: #0f766e;
    font-weight: 700;
    font-size: 0.79rem;
    letter-spacing: 0.075em;
    text-transform: uppercase;
  }

  .hero h1 {
    margin: 0.42rem 0 0.55rem;
  }

  .hero-desc {
    margin: 0;
    max-width: 62ch;
    color: var(--text-soft);
  }

  .list-section {
    margin-top: 0.9rem;
  }

  .list-title {
    margin-top: 0;
    margin-bottom: 0.72rem;
  }
</style>
