---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  DEFAULT_LANG,
  buildHomeTitle,
  collectSiteLangs,
  getLangLabel,
  getLocaleCode,
  getSiteName,
  getUi,
} from '../lib/i18n';

const lang = DEFAULT_LANG;
const ui = getUi(lang);
const siteName = getSiteName(lang);
const localeCode = getLocaleCode(lang);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const siteLangs = collectSiteLangs(allPosts.map((post) => post.data.locale));
const posts = allPosts.filter((post) => post.data.locale === lang).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
const siteBase = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(baseUrl, siteBase).toString();

const alternates = siteLangs.map((code) => ({
  hrefLang: getLocaleCode(code),
  href: new URL(code === lang ? baseUrl : `${baseUrl}${code}/`, siteBase).toString(),
}));
alternates.push({ hrefLang: 'x-default', href: canonical });

const languageLinks = siteLangs.map((code) => ({
  label: getLangLabel(code),
  href: code === lang ? baseUrl : `${baseUrl}${code}/`,
  active: code === lang,
}));

const title = buildHomeTitle(lang, siteName);
const description = ui.heroDesc;

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: canonical,
  inLanguage: localeCode,
  description,
};

const getPostSlug = (id: string) => id.split('/').pop() ?? id;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lang={lang}
  localeCode={localeCode}
  siteName={siteName}
  homeLabel={ui.home}
  blogLabel={ui.blog}
  footerText={ui.footer}
  navHomeHref={baseUrl}
  navBlogHref={`${baseUrl}${lang}/blog/`}
  languageLabel={ui.languageSwitch}
  languageLinks={languageLinks}
  alternates={alternates}
  jsonLd={websiteJsonLd}
>
  <section class="hero">
    <p class="eyebrow">{ui.heroEyebrow}</p>
    <h1>{ui.heroTitle}</h1>
    <p>{ui.heroDesc}</p>
  </section>

  <section>
    <h2>{ui.latestPosts}</h2>
    {posts.length === 0 ? (
      <p>{ui.noPosts}</p>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li class="card">
            <a href={`${baseUrl}${lang}/blog/${getPostSlug(post.id)}/`}>
              <h3>{post.data.title}</h3>
            </a>
            <p>{post.data.description}</p>
            <p class="meta">
              {post.data.pubDate.toISOString().slice(0, 10)} · {post.data.tags.join(' / ')}
            </p>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .hero {
    background: #ffffff;
    border: 1px solid #dbe5ef;
    border-radius: 1rem;
    padding: 1.2rem 1.2rem 1.1rem;
    box-shadow: 0 6px 20px rgba(15, 23, 42, 0.06);
    margin-bottom: 1.5rem;
  }

  .eyebrow {
    margin: 0;
    color: #0f766e;
    font-weight: 700;
    font-size: 0.88rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .card {
    background: #ffffff;
    border: 1px solid #dbe5ef;
    border-radius: 0.9rem;
    padding: 1rem 1rem 0.8rem;
  }

  .card h3 {
    margin-top: 0;
    margin-bottom: 0.4rem;
  }

  .card p {
    margin: 0.3rem 0;
  }

  .meta {
    color: #64748b;
    font-size: 0.9rem;
  }
</style>
