---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCardList from '../components/PostCardList.astro';
import {
  DEFAULT_LANG,
  buildHomeTitle,
  collectSiteLangs,
  getLangLabel,
  getLocaleCode,
  getSiteName,
  getUi,
} from '../lib/i18n';

const lang = DEFAULT_LANG;
const ui = getUi(lang);
const siteName = getSiteName(lang);
const localeCode = getLocaleCode(lang);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const siteLangs = collectSiteLangs(allPosts.map((post) => post.data.locale));
const posts = allPosts.filter((post) => post.data.locale === lang).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
const siteBase = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(baseUrl, siteBase).toString();

const alternates = siteLangs.map((code) => ({
  hrefLang: getLocaleCode(code),
  href: new URL(code === lang ? baseUrl : `${baseUrl}${code}/`, siteBase).toString(),
}));
alternates.push({ hrefLang: 'x-default', href: canonical });

const languageLinks = siteLangs.map((code) => ({
  label: getLangLabel(code),
  href: code === lang ? baseUrl : `${baseUrl}${code}/`,
  active: code === lang,
}));

const title = buildHomeTitle(lang, siteName);
const description = ui.heroDesc;
const getCoverImageSrc = (src?: string) => (src ? (/^https?:\/\//.test(src) ? src : `${baseUrl}${src.replace(/^\/+/, '')}`) : undefined);

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: canonical,
  inLanguage: localeCode,
  description,
};

const getPostSlug = (id: string) => id.split('/').pop() ?? id;
const postCards = posts.map((post) => ({
  href: `${baseUrl}${lang}/blog/${getPostSlug(post.id)}/`,
  title: post.data.title,
  summary: post.data.summary,
  category: post.data.category,
  coverImageSrc: getCoverImageSrc(post.data.coverImage),
  meta: `${post.data.pubDate.toISOString().slice(0, 10)} · ${post.data.tags.join(' / ')}`,
}));
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lang={lang}
  localeCode={localeCode}
  siteName={siteName}
  homeLabel={ui.home}
  blogLabel={ui.blog}
  footerText={ui.footer}
  navHomeHref={baseUrl}
  navBlogHref={`${baseUrl}${lang}/blog/`}
  languageLabel={ui.languageSwitch}
  languageLinks={languageLinks}
  alternates={alternates}
  jsonLd={websiteJsonLd}
>
  <section class="hero">
    <p class="eyebrow">{ui.heroEyebrow}</p>
    <h1>{ui.heroTitle}</h1>
    <p class="hero-desc">{ui.heroDesc}</p>
  </section>

  <section class="list-section">
    <h2 class="list-title">{ui.latestPosts}</h2>
    {postCards.length === 0 ? (
      <p>{ui.noPosts}</p>
    ) : (
      <PostCardList items={postCards} titleTag="h3" />
    )}
  </section>
</BaseLayout>

<style>
  .hero {
    background:
      linear-gradient(180deg, rgba(236, 254, 255, 0.68) 0%, rgba(255, 255, 255, 0.92) 48%, #ffffff 100%),
      repeating-linear-gradient(90deg, transparent 0, transparent 22px, rgba(15, 23, 42, 0.018) 22px, rgba(15, 23, 42, 0.018) 23px);
    border: 1px solid var(--line);
    border-radius: 1rem;
    padding: 1.3rem 1.2rem 1.18rem;
    box-shadow: var(--shadow-card);
    margin-bottom: 1.4rem;
  }

  .eyebrow {
    margin: 0;
    color: #0f766e;
    font-weight: 700;
    font-size: 0.79rem;
    letter-spacing: 0.075em;
    text-transform: uppercase;
  }

  .hero h1 {
    margin: 0.42rem 0 0.55rem;
  }

  .hero-desc {
    margin: 0;
    max-width: 62ch;
    color: var(--text-soft);
  }

  .list-section {
    margin-top: 0.9rem;
  }

  .list-title {
    margin-top: 0;
    margin-bottom: 0.72rem;
  }

</style>
