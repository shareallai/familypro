---
import SEO from '../components/SEO.astro';
import GoogleVerification from '../components/GoogleVerification.astro';
import { getSponsorCtaCopy } from '../lib/sponsorCtaCopy';

interface Props {
  title: string;
  description: string;
  canonical: string;
  lang: string;
  localeCode: string;
  siteName: string;
  homeLabel: string;
  blogLabel: string;
  footerText: string;
  navHomeHref: string;
  navBlogHref: string;
  languageLabel: string;
  languageLinks: Array<{ label: string; href: string; active?: boolean }>;
  alternates?: Array<{ hrefLang: string; href: string }>;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  canonical,
  lang,
  localeCode,
  siteName,
  homeLabel,
  blogLabel,
  footerText,
  navHomeHref,
  navBlogHref,
  languageLabel,
  languageLinks,
  alternates = [],
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  tags = [],
  jsonLd,
} = Astro.props;

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
const canonicalOrigin = new URL(canonical).origin;
const faviconSvgHref = new URL(`${baseUrl}favicon.svg`, canonicalOrigin).toString();
const faviconIcoHref = new URL(`${baseUrl}favicon.ico`, canonicalOrigin).toString();
const faviconPng48Href = new URL(`${baseUrl}favicon-48x48.png`, canonicalOrigin).toString();
const faviconPng96Href = new URL(`${baseUrl}favicon-96x96.png`, canonicalOrigin).toString();
const appleTouchIconHref = new URL(`${baseUrl}apple-touch-icon.png`, canonicalOrigin).toString();
const manifestHref = new URL(`${baseUrl}site.webmanifest`, canonicalOrigin).toString();
const sitemapHref = `${baseUrl}sitemap.xml`;
const activeLanguage = languageLinks.find((item) => item.active) ?? languageLinks[0];
const sponsorCta = getSponsorCtaCopy(lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      siteName={siteName}
      locale={localeCode}
      image={image}
      alternates={alternates}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      tags={tags}
      jsonLd={jsonLd}
    />
    <GoogleVerification />
    <link rel="icon" type="image/svg+xml" href={faviconSvgHref} />
    <link rel="icon" type="image/png" sizes="96x96" href={faviconPng96Href} />
    <link rel="icon" type="image/png" sizes="48x48" href={faviconPng48Href} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleTouchIconHref} />
    <link rel="shortcut icon" href={faviconIcoHref} />
    <link rel="manifest" href={manifestHref} />
    <link rel="sitemap" href={sitemapHref} />
  </head>
  <body>
    <header class="site-header">
      <div class="container nav-wrap">
        <div class="nav-left">
          <a class="brand" href={navHomeHref}>{siteName}</a>
        </div>
        <nav class="site-nav" aria-label="Primary">
          <a href={navHomeHref}>{homeLabel}</a>
          <a href={navBlogHref}>{blogLabel}</a>
          <a
            class="site-nav-sponsor"
            href={sponsorCta.href}
            target="_blank"
            rel="nofollow sponsored noopener noreferrer"
            aria-label={sponsorCta.navAriaLabel}
          >
            {sponsorCta.navLabel}
          </a>
        </nav>
        <div class="nav-right">
          <details class="lang-menu">
            <summary class="lang-menu-summary" aria-label={languageLabel}>
              <span class="lang-menu-icon" aria-hidden="true">🌐</span>
              <span class="lang-menu-current">{activeLanguage?.label ?? languageLabel}</span>
              <span class="lang-menu-caret" aria-hidden="true">▾</span>
            </summary>
            <ul class="lang-menu-list">
              {languageLinks.map((item) => (
                <li>
                  <a
                    class={`lang-menu-link ${item.active ? 'active' : ''}`}
                    href={item.href}
                    aria-current={item.active ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </details>
        </div>
      </div>
    </header>

    <main class="container content">
      <slot />
    </main>

    <footer class="container site-footer">
      <p>{footerText}</p>
    </footer>
  </body>
</html>

<style>
  :root {
    --container-max: 1120px;
    --container-vw: 94vw;
    --bg: #f6f8fb;
    --bg-grid: #e8eef5;
    --card: #ffffff;
    --card-muted: #f8fafc;
    --text: #0f172a;
    --text-soft: #334155;
    --muted: #64748b;
    --line: #e2e8f0;
    --line-strong: #cbd5e1;
    --brand: #0f766e;
    --brand-soft: #ecfeff;
    --shadow-card: 0 1px 2px rgba(15, 23, 42, 0.05), 0 18px 36px -28px rgba(15, 23, 42, 0.48);
    --shadow-float: 0 20px 40px -34px rgba(15, 23, 42, 0.52);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: "Plus Jakarta Sans", "Noto Sans SC", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
    background:
      radial-gradient(circle at 12% -2%, rgba(15, 118, 110, 0.1) 0%, rgba(15, 118, 110, 0) 40%),
      linear-gradient(180deg, #fbfdff 0%, var(--bg) 28%, #f4f7fb 100%);
    color: var(--text);
    line-height: 1.72;
    text-rendering: optimizeLegibility;
  }

  .container {
    width: min(var(--container-max), var(--container-vw));
    margin: 0 auto;
  }

  .site-header {
    background: rgba(255, 255, 255, 0.84);
    border-bottom: 1px solid var(--line);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .nav-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 1.25rem;
    padding: 0.86rem 0;
  }

  .nav-left {
    justify-self: start;
    min-width: 0;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-self: center;
  }

  .nav-right {
    display: inline-flex;
    align-items: center;
    justify-self: end;
    white-space: nowrap;
  }

  .lang-menu {
    position: relative;
  }

  .lang-menu summary::-webkit-details-marker {
    display: none;
  }

  .lang-menu-summary {
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    text-decoration: none;
    color: var(--muted);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0.34rem 0.8rem;
    font-size: 0.84rem;
    font-weight: 600;
    background: var(--card);
    cursor: pointer;
    user-select: none;
  }

  .lang-menu-icon {
    font-size: 0.86rem;
    line-height: 1;
  }

  .lang-menu[open] .lang-menu-summary {
    color: #0f766e;
    border-color: #99f6e4;
    background: var(--brand-soft);
  }

  .lang-menu-caret {
    font-size: 0.72rem;
    line-height: 1;
    transform: translateY(1px);
  }

  .lang-menu-list {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0.35rem;
    position: absolute;
    top: calc(100% + 0.35rem);
    right: 0;
    min-width: 150px;
    border: 1px solid var(--line-strong);
    border-radius: 0.8rem;
    background: var(--card);
    box-shadow: var(--shadow-float);
    z-index: 30;
  }

  .lang-menu[open] .lang-menu-list {
    display: grid;
    gap: 0.2rem;
  }

  .lang-menu-link {
    display: block;
    text-decoration: none;
    color: var(--muted);
    border: 1px solid transparent;
    border-radius: 0.6rem;
    padding: 0.24rem 0.52rem;
    font-size: 0.82rem;
    font-weight: 600;
  }

  .lang-menu-link:hover {
    color: #0f766e;
    background: var(--brand-soft);
    border-color: #99f6e4;
  }

  .lang-menu-link.active {
    color: #0f766e;
    border-color: #99f6e4;
    background: var(--brand-soft);
    font-weight: 700;
  }

  .brand {
    color: var(--brand);
    font-weight: 800;
    font-size: 1.06rem;
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .site-nav a {
    color: var(--muted);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.32rem 0.7rem;
  }

  .site-nav a:hover,
  .site-nav a:focus-visible {
    color: var(--brand);
    border-color: var(--line);
    background: var(--card-muted);
  }

  .site-nav a.site-nav-sponsor {
    color: #0f766e;
    border-color: #99f6e4;
    background: linear-gradient(180deg, #f0fdfa 0%, #ecfeff 100%);
    font-weight: 700;
  }

  .site-nav a.site-nav-sponsor:hover,
  .site-nav a.site-nav-sponsor:focus-visible {
    color: #115e59;
    border-color: #5eead4;
    background: linear-gradient(180deg, #ccfbf1 0%, #d1fae5 100%);
  }

  .content {
    padding: 2.1rem 0 3.2rem;
  }

  .site-footer {
    padding: 1.25rem 0 2.3rem;
    color: var(--muted);
    font-size: 0.88rem;
    border-top: 1px solid var(--line);
  }

  :global(h1) {
    line-height: 1.22;
    margin-top: 0;
    margin-bottom: 0.85rem;
    letter-spacing: -0.022em;
    font-size: clamp(1.56rem, 1.15rem + 1.2vw, 2.3rem);
    max-width: 30ch;
  }

  :global(h2) {
    margin-top: 1.9rem;
    margin-bottom: 0.62rem;
    letter-spacing: -0.018em;
    font-size: clamp(1.16rem, 1.03rem + 0.5vw, 1.52rem);
  }

  :global(h3) {
    letter-spacing: -0.01em;
    margin-bottom: 0.44rem;
    font-size: clamp(1.04rem, 0.98rem + 0.25vw, 1.19rem);
  }

  :global(p) {
    color: var(--text-soft);
  }

  :global(strong) {
    color: var(--text);
  }

  :global(a) {
    color: #0c766e;
    text-decoration-thickness: 1.4px;
    text-underline-offset: 0.16em;
  }

  :global(a:hover) {
    color: #0b5f59;
  }

  :global(code) {
    font-family: "JetBrains Mono", "SFMono-Regular", "Cascadia Code", "Fira Code", monospace;
    background: #eff3f8;
    border: 1px solid #dce3ed;
    border-radius: 0.36rem;
    padding: 0.04rem 0.32rem;
    font-size: 0.9em;
  }

  /* Keep inline code styling, but do not overlay light backgrounds inside fenced code blocks. */
  :global(pre.astro-code code) {
    background: transparent;
    border: 0;
    border-radius: 0;
    padding: 0;
    font-size: inherit;
    color: inherit;
  }

  :global(table) {
    width: 100%;
    border-collapse: collapse;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 0.75rem;
    overflow: hidden;
  }

  :global(th),
  :global(td) {
    border-bottom: 1px solid var(--line);
    padding: 0.7rem 0.8rem;
    text-align: left;
    font-size: 0.96rem;
  }

  :global(th) {
    background: #f2f7fc;
    color: var(--text);
  }

  :global(tr:last-child td) {
    border-bottom: 0;
  }

  :global(pre.astro-code) {
    border: 1px solid #1f2937;
    border-radius: 0.9rem;
    padding: 1rem;
    box-shadow: var(--shadow-card);
  }

  :global(pre.astro-code span[style*="#6A737D"]),
  :global(pre.astro-code span[style*="#6a737d"]) {
    color: #9aa4b2 !important;
  }

  @media (max-width: 720px) {
    .content {
      padding-top: 1.35rem;
    }

    .nav-wrap {
      grid-template-columns: minmax(0, 1fr) auto;
      grid-template-areas:
        "brand brand"
        "nav lang";
      row-gap: 0.68rem;
      column-gap: 0.75rem;
    }

    .nav-left {
      grid-area: brand;
    }

    .site-nav {
      grid-area: nav;
      gap: 0.32rem;
      justify-content: flex-start;
      justify-self: start;
    }

    .nav-right {
      grid-area: lang;
      justify-self: end;
    }

    .lang-menu-list {
      min-width: 170px;
      max-width: min(86vw, 320px);
      right: 0;
      left: auto;
    }

    :global(table) {
      display: block;
      overflow-x: auto;
      white-space: nowrap;
    }
  }
</style>
