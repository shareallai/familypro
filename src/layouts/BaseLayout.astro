---
import SEO from '../components/SEO.astro';
import GoogleVerification from '../components/GoogleVerification.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  lang: string;
  localeCode: string;
  siteName: string;
  homeLabel: string;
  blogLabel: string;
  footerText: string;
  navHomeHref: string;
  navBlogHref: string;
  languageLabel: string;
  languageLinks: Array<{ label: string; href: string; active?: boolean }>;
  alternates?: Array<{ hrefLang: string; href: string }>;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  canonical,
  lang,
  localeCode,
  siteName,
  homeLabel,
  blogLabel,
  footerText,
  navHomeHref,
  navBlogHref,
  languageLabel,
  languageLinks,
  alternates = [],
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  tags = [],
  jsonLd,
} = Astro.props;

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
const sitemapHref = `${baseUrl}sitemap-index.xml`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      siteName={siteName}
      locale={localeCode}
      image={image}
      alternates={alternates}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      tags={tags}
      jsonLd={jsonLd}
    />
    <GoogleVerification />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link rel="icon" href={`${baseUrl}favicon.ico`} />
    <link rel="sitemap" href={sitemapHref} />
  </head>
  <body>
    <header class="site-header">
      <div class="container nav-wrap">
        <a class="brand" href={navHomeHref}>{siteName}</a>
        <nav>
          <a href={navHomeHref}>{homeLabel}</a>
          <a href={navBlogHref}>{blogLabel}</a>
        </nav>
      </div>
      <div class="container lang-wrap">
        <span class="lang-label">{languageLabel}:</span>
        <div class="lang-links">
          {languageLinks.map((item) => (
            <a class={item.active ? 'active' : ''} href={item.href} aria-current={item.active ? 'page' : undefined}>
              {item.label}
            </a>
          ))}
        </div>
      </div>
    </header>

    <main class="container content">
      <slot />
    </main>

    <footer class="container site-footer">
      <p>{footerText}</p>
    </footer>
  </body>
</html>

<style>
  :root {
    --container-max: 920px;
    --container-vw: 92vw;
    --bg: #f5f7fb;
    --card: #ffffff;
    --text: #1f2937;
    --muted: #64748b;
    --line: #dbe5ef;
    --brand: #0f766e;
    --brand-soft: #ccfbf1;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: "Noto Sans SC", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
    background: linear-gradient(180deg, #eef5ff 0%, var(--bg) 35%, #f6fbf8 100%);
    color: var(--text);
    line-height: 1.75;
  }

  .container {
    width: min(var(--container-max), var(--container-vw));
    margin: 0 auto;
  }

  .site-header {
    background: rgba(255, 255, 255, 0.9);
    border-bottom: 1px solid var(--line);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .nav-wrap {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0 0.55rem;
  }

  .lang-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 0 0.7rem;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .lang-links {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .lang-links a {
    text-decoration: none;
    color: var(--muted);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.1rem 0.6rem;
    font-size: 0.82rem;
  }

  .lang-links a.active {
    color: #0f766e;
    border-color: #67e8f9;
    background: #f0fdfa;
    font-weight: 700;
  }

  .brand {
    color: var(--brand);
    font-weight: 800;
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  nav {
    display: flex;
    gap: 1rem;
  }

  nav a {
    color: var(--muted);
    text-decoration: none;
    font-weight: 600;
  }

  nav a:hover {
    color: var(--brand);
  }

  .content {
    padding: 2.2rem 0 3rem;
  }

  .site-footer {
    padding: 1.25rem 0 2rem;
    color: var(--muted);
    font-size: 0.92rem;
  }

  :global(h1) {
    line-height: 1.25;
    margin-top: 0;
    margin-bottom: 1rem;
  }

  :global(h2) {
    margin-top: 2rem;
    margin-bottom: 0.7rem;
  }

  :global(a) {
    color: #0f766e;
  }

  :global(table) {
    width: 100%;
    border-collapse: collapse;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 0.75rem;
    overflow: hidden;
  }

  :global(th),
  :global(td) {
    border-bottom: 1px solid var(--line);
    padding: 0.7rem 0.8rem;
    text-align: left;
    font-size: 0.96rem;
  }

  :global(th) {
    background: #f0fdf8;
  }

  :global(tr:last-child td) {
    border-bottom: 0;
  }

  :global(pre.astro-code) {
    border: 1px solid #1f2937;
    border-radius: 0.9rem;
    padding: 1rem;
  }

  :global(pre.astro-code span[style*="#6A737D"]),
  :global(pre.astro-code span[style*="#6a737d"]) {
    color: #9aa4b2 !important;
  }

  @media (max-width: 720px) {
    .content {
      padding-top: 1.4rem;
    }

    .nav-wrap {
      gap: 0.75rem;
      flex-direction: column;
      align-items: flex-start;
    }

    :global(table) {
      display: block;
      overflow-x: auto;
      white-space: nowrap;
    }
  }
</style>
