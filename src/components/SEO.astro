---
interface Props {
  title: string;
  description: string;
  canonical: string;
  siteName?: string;
  locale?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  noindex?: boolean;
  alternates?: Array<{ hrefLang: string; href: string }>;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  canonical,
  siteName = 'Subscription Savings Lab',
  locale = 'en',
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  tags = [],
  noindex = false,
  alternates = [],
  jsonLd,
} = Astro.props;

const canonicalUrl = new URL(canonical);
const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
const fallbackSocialImage = new URL(`${baseUrl}favicon.svg`, canonicalUrl.origin).toString();
const socialImage = image ? new URL(image, canonical).toString() : fallbackSocialImage;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="generator" content={Astro.generator} />
<link rel="canonical" href={canonical} />
<meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow'} />
{alternates.map((item) => <link rel="alternate" hreflang={item.hrefLang} href={item.href} />)}

<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content={locale} />
<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={socialImage} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={socialImage} />

{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{tags.map((tag) => <meta property="article:tag" content={tag} />)}

{jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
