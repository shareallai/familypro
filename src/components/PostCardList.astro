---
interface PostCardItem {
  href: string;
  title: string;
  summary: string;
  category: string;
  meta: string;
  coverImageSrc?: string;
}

interface Props {
  items: PostCardItem[];
  titleTag?: 'h2' | 'h3';
}

const { items, titleTag = 'h2' } = Astro.props as Props;
const TitleTag = titleTag;
---

<ul class="post-list">
  {items.map((item) => (
    <li class="card">
      <a href={item.href} data-astro-prefetch="viewport">
        {item.coverImageSrc && <img class="card-cover" src={item.coverImageSrc} alt={item.title} />}
        <p class="card-category">{item.category}</p>
        <TitleTag>{item.title}</TitleTag>
      </a>
      <p>{item.summary}</p>
      <p class="meta">{item.meta}</p>
    </li>
  ))}
</ul>

<style>
  .post-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.95rem;
  }

  .card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 1rem;
    padding: 1.02rem 1rem 0.9rem;
    box-shadow: var(--shadow-card);
    transition: transform 140ms ease, border-color 140ms ease, box-shadow 140ms ease;
  }

  .card:hover {
    transform: translateY(-1px);
    border-color: var(--line-strong);
    box-shadow: 0 16px 30px -28px rgba(15, 23, 42, 0.55);
  }

  .card-cover {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    max-height: 180px;
    border-radius: 0.8rem;
    border: 1px solid var(--line);
    margin-bottom: 0.85rem;
    object-fit: cover;
  }

  .card-category {
    margin: 0 0 0.25rem;
    color: #0f766e;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .card a {
    color: inherit;
    text-decoration: none;
  }

  .card a:hover h2,
  .card a:hover h3,
  .card a:focus-visible h2,
  .card a:focus-visible h3 {
    color: #0f766e;
  }

  .card h2,
  .card h3 {
    margin-top: 0;
    margin-bottom: 0.4rem;
    color: var(--text);
  }

  .card p {
    margin: 0.3rem 0;
  }

  .meta {
    color: var(--muted);
    font-size: 0.88rem;
  }
</style>
