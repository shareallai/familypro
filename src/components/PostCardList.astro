---
interface PostCardItem {
  href: string;
  title: string;
  summary: string;
  category: string;
  meta: string;
  coverImageSrc?: string;
}

interface Props {
  items: PostCardItem[];
  titleTag?: 'h2' | 'h3';
}

const { items, titleTag = 'h2' } = Astro.props as Props;
const TitleTag = titleTag;
---

<ul class="post-list">
  {items.map((item) => (
    <li class="card">
      <a href={item.href}>
        {item.coverImageSrc && <img class="card-cover" src={item.coverImageSrc} alt={item.title} />}
        <p class="card-category">{item.category}</p>
        <TitleTag>{item.title}</TitleTag>
      </a>
      <p>{item.summary}</p>
      <p class="meta">{item.meta}</p>
    </li>
  ))}
</ul>

<style>
  .post-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .card {
    background: #ffffff;
    border: 1px solid #dbe5ef;
    border-radius: 0.9rem;
    padding: 1rem 1rem 0.8rem;
  }

  .card-cover {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    max-height: 180px;
    border-radius: 0.7rem;
    border: 1px solid #dbe5ef;
    margin-bottom: 0.85rem;
    object-fit: cover;
  }

  .card-category {
    margin: 0 0 0.25rem;
    color: #0f766e;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .card h2,
  .card h3 {
    margin-top: 0;
    margin-bottom: 0.4rem;
  }

  .card p {
    margin: 0.3rem 0;
  }

  .meta {
    color: #64748b;
    font-size: 0.9rem;
  }
</style>
