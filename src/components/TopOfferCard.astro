---
interface Props {
  title: string;
  subtitle: string;
  buttonText: string;
  buttonLink: string;
}

const { title, subtitle, buttonText, buttonLink } = Astro.props as Props;
---

<section class="top-offer" aria-label={title}>
  <div class="top-offer-content">
    <p class="top-offer-title">{title}</p>
    <p class="top-offer-subtitle">{subtitle}</p>
  </div>
  <a class="top-offer-cta" href={buttonLink} rel="nofollow sponsored">
    <span>{buttonText}</span>
    <span class="top-offer-cta-arrow" aria-hidden="true">→</span>
  </a>
</section>

<style is:inline>
  .top-offer {
    margin: 0 0 1.2rem;
    padding: 1rem 1rem;
    border: 1px solid #bfdbfe;
    border-radius: 1rem;
    background: linear-gradient(180deg, #f8fbff 0%, #f0f7ff 100%);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem;
    box-shadow: var(--shadow-card);
  }

  .top-offer-content {
    min-width: 0;
    position: relative;
    padding-left: 0.8rem;
    display: grid;
    gap: 0.28rem;
  }

  .top-offer-content::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.12rem;
    bottom: 0.12rem;
    width: 2.5px;
    border-radius: 999px;
    background: linear-gradient(180deg, #60a5fa 0%, #0f766e 100%);
  }

  .top-offer-title {
    margin: 0;
    color: var(--text);
    font-size: 1.02rem;
    font-weight: 800;
    line-height: 1.4;
    letter-spacing: 0.01em;
  }

  .top-offer-subtitle {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.55;
    font-weight: 500;
    font-size: 0.9rem;
  }

  .top-offer-cta {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: #ffffff;
    background: linear-gradient(135deg, #0f766e 0%, #0f5f70 100%);
    border: 1px solid #0f766e;
    border-radius: 999px;
    padding: 0.58rem 1rem;
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1.2;
    white-space: nowrap;
    transition: background-color 120ms ease, border-color 120ms ease;
    box-shadow: 0 10px 18px -14px rgba(15, 118, 110, 0.86);
  }

  .top-offer-cta:hover,
  .top-offer-cta:focus-visible {
    background: linear-gradient(135deg, #115e59 0%, #155e75 100%);
    border-color: #115e59;
  }

  .top-offer-cta-arrow {
    font-size: 0.9rem;
    line-height: 1;
  }

  @media (max-width: 980px) {
    .top-offer {
      flex-direction: column;
      align-items: stretch;
    }

    .top-offer-cta {
      justify-content: center;
      text-align: center;
    }
  }
</style>
